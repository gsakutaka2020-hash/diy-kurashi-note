---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <SEO {...props} />
    <meta name="google-site-verification" content="uBagleSbSIHDy_3tjOhE-FFWSoKf_w6jXSB0hqk39F4" />
  </head>
  <body>
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
