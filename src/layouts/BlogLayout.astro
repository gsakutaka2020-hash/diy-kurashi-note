---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  thumbnail?: string;
}

const { title, description, pubDate, updatedDate, category, tags, thumbnail } = Astro.props;

const categoryMap: Record<string, { label: string; href: string; borderClass: string }> = {
  diy:    { label: 'DIY・リフォーム',    href: '/category/diy/',    borderClass: 'cat-border-diy' },
  gadget: { label: 'ガジェット・家電',   href: '/category/gadget/', borderClass: 'cat-border-gadget' },
  kurashi:{ label: '生活・暮らしの知恵', href: '/category/kurashi/',borderClass: 'cat-border-kurashi' },
  gundam: { label: 'ガンダム関連',       href: '/category/gundam/', borderClass: 'cat-border-gundam' },
  ai:     { label: 'AI・テクノロジー',   href: '/category/ai/',     borderClass: 'cat-border-ai' },
};

const cat = categoryMap[category] ?? { label: category, href: '/', borderClass: '' };

const formattedPub = new Date(pubDate).toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const formattedUpd = updatedDate
  ? new Date(updatedDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={thumbnail}
  ogType="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">

      <!-- 記事本文 -->
      <div>
        <Breadcrumb items={[
          { label: cat.label, href: cat.href },
          { label: title },
        ]} />

        <article>
          <!-- 記事ヘッダー -->
          <header class={`mb-8 pl-4 ${cat.borderClass}`}>
            <a href={cat.href} class="inline-block text-xs font-medium text-gray-500 hover:text-brand-600 mb-2 transition-colors">
              {cat.label}
            </a>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 leading-snug mb-4">
              {title}
            </h1>
            <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400">
              <time datetime={pubDate.toISOString()}>
                📅 公開：{formattedPub}
              </time>
              {formattedUpd && (
                <time datetime={updatedDate?.toISOString()}>
                  🔄 更新：{formattedUpd}
                </time>
              )}
            </div>
          </header>

          <!-- アイキャッチ -->
          {thumbnail && (
            <div class="mb-8 rounded-xl overflow-hidden">
              <img
                src={thumbnail}
                alt={title}
                class="w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </div>
          )}

          <!-- 本文 -->
          <div class="prose-article">
            <slot />
          </div>

          <!-- タグ -->
          {tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-gray-200">
              <p class="text-xs text-gray-500 mb-2">タグ：</p>
              <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full border border-gray-200">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </article>
      </div>

      <!-- サイドバー -->
      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <!-- プロフィールカード -->
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-3">
              <img src="/images/profile.png" alt="さっく" class="w-12 h-12 rounded-full object-cover" />
              <div>
                <p class="font-bold text-sm text-gray-900">さっく</p>
                <p class="text-xs text-gray-500">ブログ管理人</p>
              </div>
            </div>
            <p class="text-xs text-gray-600 leading-relaxed">
              古民家DIY・ガジェット好きの40代。実体験をもとにリアルな情報をお届けします。
            </p>
            <a href="/about/" class="mt-3 block text-center text-xs bg-brand-50 text-brand-700 border border-brand-200 rounded-lg py-2 hover:bg-brand-100 transition-colors">
              プロフィールを見る
            </a>
          </div>

          <!-- カテゴリ -->
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="font-bold text-sm text-gray-900 mb-3">カテゴリ</h3>
            <ul class="space-y-1.5">
              {[
                { href: '/category/diy/',    label: '🔨 DIY・リフォーム',    cls: 'hover:text-orange-600' },
                { href: '/category/gadget/', label: '📱 ガジェット・家電',   cls: 'hover:text-blue-600' },
                { href: '/category/kurashi/',label: '🌿 生活・暮らしの知恵', cls: 'hover:text-emerald-600' },
                { href: '/category/gundam/', label: '🤖 ガンダム関連',       cls: 'hover:text-purple-600' },
                { href: '/category/ai/',     label: '💡 AI・テクノロジー',   cls: 'hover:text-pink-600' },
              ].map(item => (
                <li>
                  <a href={item.href} class={`text-sm text-gray-600 transition-colors ${item.cls}`}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
