---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const siteUrl = 'https://diy-kurashi-note.com';
---

<nav aria-label="パンくずリスト" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1 text-xs text-gray-500" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" class="hover:text-brand-600 transition-colors" itemprop="item">
        <span itemprop="name">ホーム</span>
      </a>
      <meta itemprop="position" content="1" />
    </li>

    {items.map((item, i) => (
      <li class="flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="text-gray-300">›</span>
        {item.href ? (
          <a href={item.href} class="hover:text-brand-600 transition-colors" itemprop="item">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span class="text-gray-700 font-medium" itemprop="name">{item.label}</span>
        )}
        <meta itemprop="position" content={String(i + 2)} />
      </li>
    ))}
  </ol>
</nav>

<!-- JSON-LD パンくず構造化データ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ホーム",
      "item": siteUrl
    },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": item.label,
      "item": item.href ? `${siteUrl}${item.href}` : undefined,
    }))
  ]
})} />
